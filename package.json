{
  "name": "quickcart",
  "productName": "QuickCart",
  "version": "4.2.2",
  "description": "A billing software for creating and managing invoices and customer accounts.",
  "author": "Prajwal prajwalkreddy17@gmail.com",
  "main": "./out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Prajwal-17/pos"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noemit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noemit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dev": "pnpm run rebuild && cross-env MODE=development NODE_ENV=development ELECTRON_DISABLE_SANDBOX=1 electron-vite dev --mode development",
    "start": "cross-env MODE=production NODE_ENV=production ELECTRON_DISABLE_SANDBOX=1 electron-vite preview --mode production",
    "test": "vitest",
    "db:generate": "cross-env ELECTRON_RUN_AS_NODE=1 electron ./node_modules/drizzle-kit/bin.cjs generate",
    "db:seed:dev": "cross-env MODE=development ELECTRON_RUN_AS_NODE=1 electron --require tsx/cjs src/main/db/seed.ts",
    "db:seed:prod": "cross-env MODE=production ELECTRON_RUN_AS_NODE=1 electron --require tsx/cjs src/main/db/seed.ts",
    "db:migrate:dev": "cross-env MODE=development ELECTRON_RUN_AS_NODE=1 electron ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:prod": "cross-env MODE=production ELECTRON_RUN_AS_NODE=1 electron ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio:dev": "cross-env MODE=development ELECTRON_RUN_AS_NODE=1 electron ./node_modules/drizzle-kit/bin.cjs studio",
    "db:studio:prod": "cross-env MODE=production ELECTRON_RUN_AS_NODE=1 electron ./node_modules/drizzle-kit/bin.cjs studio",
    "db:push:dev": "cross-env MODE=development ELECTRON_RUN_AS_NODE=1 electron ./node_modules/drizzle-kit/bin.cjs push",
    "db:push:prod": "cross-env MODE=production ELECTRON_RUN_AS_NODE=1 electron ./node_modules/drizzle-kit/bin.cjs push",
    "build": "pnpm run typecheck && electron-vite build",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win --publish never",
    "build:mac": "electron-vite build --mode production && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux --publish never",
    "build:win:dev": "pnpm run build&& electron-builder --win --config electron-builder.dev.yml --publish never",
    "build:linux:dev": "pnpm run build && electron-builder --linux --config electron-builder.dev.yml --publish never"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@hono/node-server": "^1.19.7",
    "@hono/zod-validator": "^0.7.6",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-virtual": "^3.13.12",
    "better-sqlite3": "^12.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-state-city": "^3.2.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "hono": "^4.10.8",
    "immer": "^11.1.4",
    "jspdf": "^3.0.2",
    "jspdf-autotable": "^5.0.2",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.534.0",
    "motion": "^12.23.12",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react-day-picker": "^9.9.0",
    "react-easy-crop": "^5.5.7",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.7.1",
    "react-to-print": "^3.1.1",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.6",
    "uuid": "^11.1.0",
    "zod": "^4.1.8",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.1",
    "@faker-js/faker": "^9.9.0",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/eslint-plugin-query": "^5.91.0",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.0.16",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.4",
    "drizzle-seed": "^0.3.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-scan": "^0.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "better-sqlite3",
      "@electron/rebuild"
    ]
  }
}
